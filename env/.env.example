PORT=8001
NODE_ENV=local

# MongoDB Atlas
MONGO_URI=mongodb+srv://<USER>:<PASSWORD>@<CLUSTER>.mongodb.net/matchdb-jobs?retryWrites=true&w=majority

# JWT (must match shell-services)
JWT_SECRET=<min-32-char-secret>

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@matchdb.io
SENDGRID_FROM_NAME=MatchingDB
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000,http://localhost:4001
CLIENT_URL=http://localhost:3000
