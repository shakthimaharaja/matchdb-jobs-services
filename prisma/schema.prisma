// jobs-services: generate-only schema (never runs prisma migrate)
// shell-services owns all migrations.
// Run: npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id                 String        @id @default(uuid())
  vendorId           String
  vendorEmail        String
  recruiterName      String        @default("")
  recruiterPhone     String        @default("")
  title              String
  description        String        @default("")
  location           String        @default("")
  jobCountry         String        @default("")
  jobState           String        @default("")
  jobCity            String        @default("")
  jobType            String
  jobSubType         String        @default("")
  workMode           String        @default("")
  salaryMin          Decimal?
  salaryMax          Decimal?
  payPerHour         Decimal?
  skillsRequired     String[]
  experienceRequired Int           @default(0)
  applicationCount   Int           @default(0)
  isActive           Boolean       @default(true)
  sourceUserId       String        @default("")  // who uploaded this job (for salary attribution)
  sourceCompanyId    String        @default("")  // company unique ID for mapping
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  applications       Application[]

  @@index([vendorId, createdAt(sort: Desc)])
  @@index([isActive, createdAt(sort: Desc)])
  @@index([sourceUserId])
  @@map("jobs")
}

model CandidateProfile {
  id                 String   @id @default(uuid())
  candidateId        String   @unique
  username           String   @default("")
  name               String   @default("")
  email              String   @default("")
  phone              String   @default("")
  currentCompany     String   @default("")
  currentRole        String   @default("")
  preferredJobType   String   @default("")
  expectedHourlyRate Decimal?
  experienceYears    Int      @default(0)
  skills             String[]
  location           String   @default("")
  profileCountry     String   @default("")
  bio                String   @default("")
  resumeSummary      String   @default("")
  resumeExperience   String   @default("")
  resumeEducation    String   @default("")
  resumeAchievements String   @default("")
  visibilityConfig   Json?
  companyId          String   @default("")  // linked company unique ID
  companyName        String   @default("")  // denormalized company name
  profileLocked      Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([companyId])
  @@map("candidate_profiles")
}

model Application {
  id             String   @id @default(uuid())
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobTitle       String   @default("")
  candidateId    String
  candidateEmail String
  coverLetter    String   @default("")
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  financials     ProjectFinancial[]

  @@unique([jobId, candidateId])
  @@index([candidateId])
  @@map("applications")
}

model PokeRecord {
  id             String   @id @default(uuid())
  senderId       String
  senderName     String   @default("")
  senderEmail    String   @default("")
  senderType     String
  targetId       String
  targetVendorId String?
  targetEmail    String
  targetName     String   @default("")
  subject        String   @default("")
  isEmail        Boolean  @default(false)
  jobId          String?
  jobTitle       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([senderId, targetId, isEmail])
  @@index([senderId])
  @@index([targetId])
  @@map("poke_records")
}

model PokeLog {
  id        String   @id @default(uuid())
  userId    String
  yearMonth String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, yearMonth])
  @@map("poke_logs")
}

model Company {
  id                 String              @id @default(uuid())
  name               String
  marketerId         String              @unique
  marketerEmail      String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  marketerCandidates MarketerCandidate[]

  @@index([name])
  @@map("companies")
}

model MarketerCandidate {
  id             String   @id @default(uuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  marketerId     String
  candidateId    String   @default("")
  candidateName  String   @default("")
  candidateEmail String
  inviteStatus   String   @default("none")  // none | invited | accepted | declined
  inviteToken    String?  @unique           // one-time invite token
  inviteSentAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([companyId, candidateEmail])
  @@index([marketerId])
  @@map("marketer_candidates")
}

model ForwardedOpening {
  id             String   @id @default(uuid())
  marketerId     String
  marketerEmail  String   @default("")
  companyId      String
  companyName    String   @default("")
  candidateEmail String
  candidateName  String   @default("")
  jobId          String
  jobTitle       String   @default("")
  jobLocation    String   @default("")
  jobType        String   @default("")
  jobSubType     String   @default("")
  vendorEmail    String   @default("")
  skillsRequired String[]
  payPerHour     Decimal?
  salaryMin      Decimal?
  salaryMax      Decimal?
  note           String   @default("")
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([marketerId, candidateEmail, jobId])
  @@index([candidateEmail, createdAt(sort: Desc)])
  @@map("forwarded_openings")
}

model CompanyInvite {
  id             String   @id @default(uuid())
  companyId      String
  companyName    String   @default("")
  marketerId     String
  marketerEmail  String   @default("")
  candidateEmail String
  candidateName  String   @default("")
  token          String   @unique @default(uuid())
  offerNote      String   @default("")
  status         String   @default("pending")  // pending | accepted | declined | expired
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([companyId, candidateEmail])
  @@map("company_invites")
}

model ProjectFinancial {
  id              String   @id @default(uuid())
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  marketerId      String
  candidateId     String   @default("")
  candidateEmail  String   @default("")
  billRate        Decimal  @default(0)
  payRate         Decimal  @default(0)
  hoursWorked     Decimal  @default(0)
  projectStart    DateTime?
  projectEnd      DateTime?
  stateCode       String   @default("")
  stateTaxPct     Decimal  @default(0)
  cashPct         Decimal  @default(0)
  totalBilled     Decimal  @default(0)
  totalPay        Decimal  @default(0)
  taxAmount       Decimal  @default(0)
  cashAmount      Decimal  @default(0)
  netPayable      Decimal  @default(0)
  amountPaid      Decimal  @default(0)
  amountPending   Decimal  @default(0)
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([applicationId, marketerId])
  @@index([marketerId, candidateId])
  @@map("project_financials")
}

// status: "draft" | "submitted" | "approved" | "rejected"
// entries: [{date, day, hoursWorked, notes}]

model Timesheet {
  id             String    @id @default(uuid())
  candidateId    String
  candidateEmail String    @default("")
  candidateName  String    @default("")
  marketerId     String    @default("")
  marketerEmail  String    @default("")
  companyId      String    @default("")
  companyName    String    @default("")
  weekStart      DateTime
  weekEnd        DateTime
  entries        Json
  totalHours     Decimal   @default(0)
  status         String    @default("draft")
  submittedAt    DateTime?
  approvedAt     DateTime?
  approverNotes  String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([candidateId, weekStart])
  @@index([marketerId, status])
  @@index([candidateId, weekStart(sort: Desc)])
  @@map("timesheets")
}

// status: "pending" | "accepted" | "declined" | "cancelled"
model InterviewInvite {
  id             String    @id @default(uuid())
  vendorId       String
  vendorEmail    String    @default("")
  vendorName     String    @default("")
  candidateEmail String
  candidateName  String    @default("")
  jobId          String    @default("")
  jobTitle       String    @default("")
  meetLink       String    @default("")
  proposedAt     DateTime?
  message        String    @default("")
  status         String    @default("pending")
  respondedAt    DateTime?
  candidateNote  String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([vendorId, createdAt(sort: Desc)])
  @@index([candidateEmail, createdAt(sort: Desc)])
  @@map("interview_invites")
}
